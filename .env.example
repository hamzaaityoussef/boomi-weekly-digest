# Copiez ce fichier en ".env" pour tester en local (ne JAMAIS committer le .env réel)

# Gemini API — créer une clé sur https://aistudio.google.com/apikey
# Format attendu : AIzaSy... (certaines clés récentes peuvent avoir un autre préfixe)
GOOGLE_API_KEY=votre_cle_ici

# Modèle Gemini (optionnel). Par défaut : gemini-flash-lite-latest
# Testez avec : python scripts/test_gemini.py
# GEMINI_MODEL=gemini-flash-lite-latest

# Teams Workflow webhook URL (Power Automate)
TEAMS_WEBHOOK_URL=https://defaultXXXXXXX.ea.environment.api.powerplatform.com/powerautomate/...

# Désactiver la vérification SSL si nécessaire (certificat auto-signé en réseau d'entreprise)
TEAMS_SKIP_SSL_VERIFY=1
